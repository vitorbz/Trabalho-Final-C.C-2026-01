import java.util.Scanner;

public class Jogo {

    public Jogo() {

        String[] mapaIlha = new String[15];
        boolean[] posicaoExplorada = new boolean[15];

        inicializarIlha(mapaIlha);

        iniciar(mapaIlha, posicaoExplorada);
    }

    public void iniciar(String[] mapaIlha, boolean[] posicaoExplorada) {

        Scanner leitor = new Scanner(System.in);

        int pontosTotaisDoJogo = 0;
        int tesourosEncontrados = 0;
        int armadilhasEncontradas = 0;
        int espacosVaziosEncontrados = 0;
        int tentativasRestantes = 8;

        int opcaoMenu;
        String jogarNovamente = "";

        do {
            do {

                exibirMenu();
                opcaoMenu = lerOpcaoMenu(leitor);

                System.out.println("Você escolheu a opção: " + opcaoMenu + "\n");

                if (opcaoMenu == 1) {
                    exibirInstrucoes();
                } else if (opcaoMenu == 2) {
                    mostrarMapa(posicaoExplorada, mapaIlha);
                } else if (opcaoMenu == 3) {

                    String resultado = jogar(leitor, posicaoExplorada, mapaIlha);

                    if (resultado.equals("VAZIO")) {
                        espacosVaziosEncontrados++;
                        tentativasRestantes--;

                    } else if (resultado.equals("OURO")) {
                        pontosTotaisDoJogo += 10;
                        tesourosEncontrados++;
                        tentativasRestantes--;

                    } else if (resultado.equals("DIAMANTE")) {
                        pontosTotaisDoJogo += 20;
                        tesourosEncontrados++;
                        tentativasRestantes--;

                    } else if (resultado.equals("RUBI")) {
                        pontosTotaisDoJogo += 15;
                        tesourosEncontrados++;
                        tentativasRestantes--;

                    } else if (resultado.equals("BURACO")) {
                        pontosTotaisDoJogo -= 5;
                        armadilhasEncontradas++;
                        tentativasRestantes--;

                    } else if (resultado.equals("COBRA")) {
                        pontosTotaisDoJogo -= 10;
                        armadilhasEncontradas++;
                        tentativasRestantes--;

                    } else if (resultado.equals("ESPINHOS")) {
                        pontosTotaisDoJogo -= 7;
                        armadilhasEncontradas++;
                        tentativasRestantes--;
                    }

                } else if (opcaoMenu == 4) {

                    mostrarStatus(pontosTotaisDoJogo, tentativasRestantes, tesourosEncontrados,
                            armadilhasEncontradas, espacosVaziosEncontrados);
                }

            } while (opcaoMenu != 5 && verificarFimDeJogo(mapaIlha, tentativasRestantes, tesourosEncontrados) == false);

            mostrarValores(pontosTotaisDoJogo, tesourosEncontrados, armadilhasEncontradas, espacosVaziosEncontrados);

            System.out.println();

            jogarNovamente = perguntarReinicio(leitor);

            pontosTotaisDoJogo = 0;
            tesourosEncontrados = 0;
            armadilhasEncontradas = 0;
            espacosVaziosEncontrados = 0;
            tentativasRestantes = 8;

            for (int i = 0; i < posicaoExplorada.length; i++) {
                posicaoExplorada[i] = false;
            }
            inicializarIlha(mapaIlha);

        } while (jogarNovamente.equals("S"));

        System.out.println("Jogo encerrado.\n");
    }

    private void exibirMenu() {

        System.out.println("===== ILHA DOS TESOUROS =====");
        System.out.println("1 - Mostrar instruções");
        System.out.println("2 - Mostrar mapa");
        System.out.println("3 - Jogar");
        System.out.println("4 - Mostrar status");
        System.out.println("5 - Sair");
    }

    private int lerOpcaoMenu(Scanner informer) {

        int opcaoMenu;

        do {

            System.out.print("Escolha uma opção: ");
            opcaoMenu = informer.nextInt();

            if (opcaoMenu > 5 || opcaoMenu < 1) {
                System.out.println("A opção escolhida não existe");
            }

        } while (opcaoMenu > 5 || opcaoMenu < 1);

        return opcaoMenu;
    }

    private void exibirInstrucoes() {
        System.out.println("===== INSTRUÇÕES =====");

        System.out.println("A ilha possui 15 posições, numeradas de 0 a 14.");
        System.out.println("Você possui 8 tentativas para explorar a ilha.");
        System.out.println("Em cada jogada, escolha uma posição para explorar.");

        System.out.println("\nTESOUROS:");
        System.out.println("OURO = +10 pontos");
        System.out.println("DIAMANTE = +20 pontos");
        System.out.println("RUBI = +15 pontos");

        System.out.println("\nARMADILHAS:");
        System.out.println("BURACO = -5 pontos");
        System.out.println("COBRA = -10 pontos");
        System.out.println("ESPINHOS = -7 pontos");

        System.out.println("\nVAZIO = 0 pontos");

        System.out.println("\nVocê não pode explorar a mesma posição duas vezes.");
        System.out.println("O jogo termina quando:");
        System.out.println("- Acabarem as tentativas;");
        System.out.println("- Todos os tesouros forem encontrados;");
        System.out.println("- O jogador escolher a opção Sair.");

        System.out.println("\n======================\n");
    }

    private void mostrarMapa(boolean[] posicoesExploradas, String[] mapaIlha) {

        for (int i = 0; i < mapaIlha.length; i++) {

            if (posicoesExploradas[i] == true) {
                System.out.println("[" + i + "] EXPLORADO");

            } else {
                System.out.println("[" + i + "] ?");
            }
        }
        System.out.println();
    }

    private void inicializarIlha(String[] mapaIlha) {

        for (int i = 0; i < mapaIlha.length; i++) {
            mapaIlha[i] = sortear();
        }
    }

    private String sortear() {

        String[] tipos = {
                "VAZIO",
                "OURO",
                "DIAMANTE",
                "RUBI",
                "BURACO",
                "COBRA",
                "ESPINHOS"
        };

        int posicao = (int) (Math.random() * 7);

        return tipos[posicao];
    }

    private String jogar(Scanner informer, boolean[] posicoesExploradas, String[] mapaIlha) {

        System.out.print("Escolha a posição: ");
        int posicao = informer.nextInt();

        if (posicao < 0 || posicao > 14) {
            System.out.println("Posição invalida.");
            return "INVALIDA";
        }

        if (posicoesExploradas[posicao]) {
            System.out.println("Essa posição já foi explorada.");
            return "INVALIDA";
        }

        posicoesExploradas[posicao] = true;
        System.out.println("Você explorou a posição " + posicao);

        String tipo = mapaIlha[posicao];

        if (tipo.equals("VAZIO")) {
            System.out.println("Você encontrou VAZIO! Nenhum ponto somado ou subtraído");

        } else if (tipo.equals("OURO")) {
            System.out.println("Você encontrou OURO! +10 pontos");

        } else if (tipo.equals("DIAMANTE")) {
            System.out.println("Você encontrou DIAMANTE! +20 pontos");

        } else if (tipo.equals("RUBI")) {
            System.out.println("Você encontrou RUBI! +15 pontos");

        } else if (tipo.equals("BURACO")) {
            System.out.println("Você encontrou BURACO! -5 pontos");

        } else if (tipo.equals("COBRA")) {
            System.out.println("Você encontrou COBRA! -10 pontos");

        } else if (tipo.equals("ESPINHOS")) {
            System.out.println("Você encontrou ESPINHOS! -7 pontos");
        }

        System.out.println();

        return tipo;
    }

    private void mostrarStatus(int pontosTotaisDoJogo, int tentativasRestantes, int tesourosEncontrados,
            int armadilhasEncontradas, int espacosVaziosEncontrados) {

        System.out.println("Pontuação atual: " + pontosTotaisDoJogo + " pontos");
        System.out.println("Quantidade de tentativas restantes : " + tentativasRestantes);
        System.out.println("Quantidade de tesouros encontrados: " + tesourosEncontrados);
        System.out.println("Quantidade de armadilhas encontradas : " + armadilhasEncontradas);
        System.out.println("Quantidade de posições vazias encontradas : " + espacosVaziosEncontrados + "\n");
    }

    private String perguntarReinicio(Scanner informer) {

        String jogarNovamente = "";
        boolean repetir = false;

        do {

            System.out.print("FIM de jogo. Deseja jogar novamente? (S/N): ");
            jogarNovamente = informer.next().toUpperCase();

            if (jogarNovamente.equals("S") || jogarNovamente.equals("N")) {
                repetir = false; 
            } else {
                System.out.println("Digite S (sim) ou N (não)");
                repetir = true;
            }

        } while (repetir);

        return jogarNovamente;
    }

    private boolean verificarFimDeJogo(String[] mapaIlha, int tentativasRestantes, int tesourosEncontrados) {

        if (tentativasRestantes <= 0) {
            return true;
        }

        int totalTesouros = 0;
        for (int i = 0; i < mapaIlha.length; i++) {
            if (mapaIlha[i].equals("OURO")
                    || mapaIlha[i].equals("DIAMANTE")
                    || mapaIlha[i].equals("RUBI")) {
                totalTesouros++;
            }
        }

        if (totalTesouros > 0 && tesourosEncontrados >= totalTesouros) {
            return true;
        }

        return false;
    }

    private void mostrarValores(int pontosTotaisDoJogos, int tesourosEncontrado, int armadilhasEncontrada,
            int espacosVaziosEncontrados) {
        System.out.println("\nTesouros encontrados: " + tesourosEncontrado);
        System.out.println("Armadilhas encontradas: " + armadilhasEncontrada);
        System.out.println("Posições vazias exploradas: " + espacosVaziosEncontrados);
        System.out.println("Pontuação final: " + pontosTotaisDoJogos);
    }
}
