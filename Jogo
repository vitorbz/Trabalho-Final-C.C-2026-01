import java.util.Scanner;

public class Jogo {

    private int pontosTotaisDoJogo = 0;
    private int tesourosEncontrados = 0;
    private int armadilhasEncontradas = 0;
    private int espacosVaziosEncontradios = 0;
    private int tentativasRestantes = 8;

    public Jogo() {

        Scanner leitor = new Scanner(System.in);

        String mapailha[] = new String[15];
        boolean posicaoEplorada[] = new boolean[15];

        inicializarIlha(mapailha);

        int opcaoMenu;
        String JogarNovamente = "";

        do {
            do {

                exibirMenu();
                opcaoMenu = lerOpcaoMenu(leitor);

                System.out.println("Você escolheu a opção: " + opcaoMenu + "\n");

                if (opcaoMenu == 1) {
                    opcaoMenu1();
                } else if (opcaoMenu == 2) {
                    opcaoMenu2(posicaoEplorada, mapailha);
                } else if (opcaoMenu == 3) {
                    opcaoMenu3(leitor, posicaoEplorada, mapailha);
                } else if (opcaoMenu == 4) {
                    opcaoMenu4();
                }

            } while (opcaoMenu != 5 && verificarFimDeJogo(mapailha) == false);

            JogarNovamente = opcaoMenu5(leitor);

            pontosTotaisDoJogo = 0;
            tesourosEncontrados = 0;
            armadilhasEncontradas = 0;
            espacosVaziosEncontradios = 0;
            tentativasRestantes = 8;
            for (int i = 0; i < posicaoEplorada.length; i++) {
                posicaoEplorada[i] = false;
            }
            inicializarIlha(mapailha);

        } while (JogarNovamente.equals("S"));
    }

    private void exibirMenu() {

        System.out.println("===== ILHA DOS TESOUROS =====");
        System.out.println("1 - Mostrar instruções");
        System.out.println("2 - Mostrar mapa");
        System.out.println("3 - Jogar");
        System.out.println("4 - Mostrar status");
        System.out.println("5 - Sair");
    }

    private int lerOpcaoMenu(Scanner informer) {

        int opcaoMenu;

        do {

            System.out.print("Escolha uma opção: ");
            opcaoMenu = informer.nextInt();

            if (opcaoMenu > 5 || opcaoMenu < 1) {
                System.out.println("A opção escolhida não existe");
            }

        } while (opcaoMenu > 5 || opcaoMenu < 1);

        return opcaoMenu;
    }

    private void opcaoMenu1() {
        System.out.println("===== INSTRUÇÕES =====");

        System.out.println("A ilha possui 15 posições, numeradas de 0 a 14.");
        System.out.println("Você possui 8 tentativas para explorar a ilha.");
        System.out.println("Em cada jogada, escolha uma posição para explorar.");

        System.out.println("\nTESOUROS:");
        System.out.println("OURO = +10 pontos");
        System.out.println("DIAMANTE = +20 pontos");
        System.out.println("RUBI = +15 pontos");

        System.out.println("\nARMADILHAS:");
        System.out.println("BURACO = -5 pontos");
        System.out.println("COBRA = -10 pontos");
        System.out.println("ESPINHOS = -7 pontos");

        System.out.println("\nVAZIO = 0 pontos");

        System.out.println("\nVocê não pode explorar a mesma posição duas vezes.");
        System.out.println("O jogo termina quando:");
        System.out.println("- Acabarem as tentativas;");
        System.out.println("- Todos os tesouros forem encontrados;");
        System.out.println("- O jogador escolher a opção Sair.");

        System.out.println("\n======================\n");
    }

    private void opcaoMenu2(boolean[] posicoesEploradas, String[] mapasIlha) {

        for (int i = 0; i < mapasIlha.length; i++) {

            if (posicoesEploradas[i] == true) {
                System.out.println("[" + i + "] EXPLORADO");

            } else {
                System.out.println("[" + i + "] ?");
            }
        }
        System.out.println();
    }

    private void inicializarIlha(String[] mapasIlha) {

        String[] tipos = {
                "VAZIO",
                "OURO",
                "DIAMANTE",
                "RUBI",
                "BURACO",
                "COBRA",
                "ESPINHOS"
        };

        for (int i = 0; i < mapasIlha.length; i++) {

            int sorteio = (int) (Math.random() * 7);

            mapasIlha[i] = tipos[sorteio];
        }
    }

    private void opcaoMenu3(Scanner informer, boolean[] mapasExplorados, String[] mapasIlha) {

        System.out.print("Escolha a posição: ");
        int posicao = informer.nextInt();

        if (posicao < 0 || posicao > 14) {
            System.out.println("Posição invalida.");
            return;
        }

        if (mapasExplorados[posicao]) {
            System.out.println("Essa posição já foi explorada.");
            return;

        }
        mapasExplorados[posicao] = true;
        System.out.println("Você explorou a posição " + posicao);

        if (mapasIlha[posicao].equals("VAZIO")) {
            System.out.println("Você encontrou VAZIO! Nenhum ponto somado ou subtraído");
            espacosVaziosEncontradios++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("OURO")) {
            System.out.println("Você encontrou OURO! +10 pontos");
            pontosTotaisDoJogo += 10;
            tesourosEncontrados++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("DIAMANTE")) {
            System.out.println("Você encontrou DIAMANTE! +20 pontos");
            pontosTotaisDoJogo += 20;
            tesourosEncontrados++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("RUBI")) {
            System.out.println("Você encontrou RUBI! +15 pontos");
            pontosTotaisDoJogo += 15;
            tesourosEncontrados++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("BURACO")) {
            System.out.println("Você encontrou BURACO! -5 pontos");
            pontosTotaisDoJogo -= 5;
            armadilhasEncontradas++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("COBRA")) {
            System.out.println("Você encontrou COBRA! -10 pontos");
            pontosTotaisDoJogo -= 10;
            armadilhasEncontradas++;
            tentativasRestantes--;

        } else if (mapasIlha[posicao].equals("ESPINHOS")) {
            System.out.println("Você encontrou ESPINHOS! -7 pontos");
            pontosTotaisDoJogo -= 7;
            armadilhasEncontradas++;
            tentativasRestantes--;

        }
        System.out.println();
    }

    private void opcaoMenu4() {

        System.out.println("Pontuação atual: " + pontosTotaisDoJogo);
        System.out.println("Quantidade de tentativas restantes : " + tentativasRestantes);
        System.out.println("Quantidade de tesouros encontrados: " + tesourosEncontrados);
        System.out.println("Quantidade de armadilhas encontradas : " + armadilhasEncontradas);
        System.out.println("Quantidade de posições vazias encontradas : " + espacosVaziosEncontradios + "\n");
    }

    private String opcaoMenu5(Scanner informer) {

        System.out.print("FIM de jogo. Deseja jogar novamente? (S/N): ");
        String jogarNovamente = informer.next();
        return jogarNovamente;
    }


    private boolean verificarFimDeJogo(String[] mapasIlha) {

        if (tentativasRestantes <= 0) {
            return true;
        }

        int totalTesouros = 0;
        for (int i = 0; i < mapasIlha.length; i++) {
            if (mapasIlha[i].equals("OURO")
                    || mapasIlha[i].equals("DIAMANTE")
                    || mapasIlha[i].equals("RUBI")) {
                totalTesouros++;
            }
        }

        if (totalTesouros > 0 && tesourosEncontrados >= totalTesouros) {
            return true;
        }

        return false;
    }
}
